@echo off
chcp 65001 > nul
title معالج تحويل GTAV Mod Manager إلى EXE
color 0B
echo ==========================================================
echo       مرحباً بك في معالج بناء تطبيق GTAV Mod Manager
echo ==========================================================
echo.
echo سيقوم هذا الملف بإعداد وتثبيت كافة المتطلبات وتحويل موقع الويب 
echo الخاص بك إلى برنامج Windows (.exe) متكامل بخطوة واحدة سهلة!
echo.
echo ----------------------------------------------------------
echo الخطوة 1: فحص بيئة عمل Node.js و NPM...
echo ----------------------------------------------------------
node -v >nul 2>&1
if %errorlevel% neq 0 (
    color 0C
    echo [خطأ] Node.js غير مثبت على جهازك!
    echo يرجى تحميله وتثبيته أولاً من الموقع الرسمي: https://nodejs.org
    echo ثم أعد تشغيل هذا الملف.
    pause
    exit
)
echo [نجاح] Node.js مثبت بالفعل.
echo.

echo ----------------------------------------------------------
echo الخطوة 2: تثبيت الحزم والمكتبات اللازمة محلياً...
echo ----------------------------------------------------------
echo يرجى الانتظار، قد تستغرق هذه العملية دقيقة أو دقيقتين...
call npm install
if %errorlevel% neq 0 (
    echo [تنبيه] قد تكون هناك مشكلة في تثبيت بعض الحزم، سنحاول المتابعة...
)
echo.

echo ----------------------------------------------------------
echo الخطوة 3: بناء ملفات الويب بشكل صحيح (Relativizing Assets)...
echo ----------------------------------------------------------
call npm run build
if %errorlevel% neq 0 (
    color 0C
    echo [خطأ] فشلت عملية بناء ملفات الويب (vite build)!
    pause
    exit
)
echo [نجاح] تم بناء ملفات الويب بنجاح داخل مجلد dist.
echo.

echo ----------------------------------------------------------
echo الخطوة 4: تحويل التطبيق إلى ملف EXE...
echo ----------------------------------------------------------
echo سنقوم الآن باستخدام تطبيق electron-packager السريع والآمن
echo لبناء حزمة التشغيل مباشرة...
echo.
npx electron-packager . "GTAV Mod Manager" --platform=win32 --arch=x64 --out=dist-exe --overwrite --prune=true

if %errorlevel% neq 0 (
    color 0C
    echo.
    echo [خطأ] فشل تحويل التطبيق إلى EXE. تأكد من إغلاق أي نسخة مفتوحة من البرنامج.
    pause
    exit
)

color 0A
echo ==========================================================
echo         🎉 مبروووك! تم تحويل التطبيق بنجاح! 🎉
echo ==========================================================
echo.
echo ستجد البرنامج الجاهز للتشغيل داخل المجلد التالي:
echo dist-exe\GTAV Mod Manager-win32-x64\GTAV Mod Manager.exe
echo.
echo يمكنك الآن نقل هذا المجلد وتشغيل البرنامج مباشرة على أي جهاز!
echo.
explorer dist-exe\GTAV Mod Manager-win32-x64
pause
